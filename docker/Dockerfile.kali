FROM kalilinux/kali-rolling:latest

RUN apt-get update && apt-get install -y --no-install-recommends \
    nmap \
    nikto \
    dnsutils \
    whois \
    curl \
    jq \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash scanner
USER scanner
WORKDIR /home/scanner

ENTRYPOINT ["sleep", "infinity"]
